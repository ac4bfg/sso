# Server
PORT=8080

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cost_control_sso
DB_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
