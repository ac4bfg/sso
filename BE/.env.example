JWT_REFRESH_EXPIRY=168h

# CORS
CORS_ORIGINS=http://localhost:3000

# Seed Admin (hanya dipakai saat pertama kali)
SEED_ADMIN_EMAIL=admin@ksm.co.id
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Administrator
